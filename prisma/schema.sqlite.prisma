generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  OWNER
  OPERATOR
  SUPPORT
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum Platform {
  SHOPEE
  TIKTOK
  MIAOSHOU
  INTERNAL
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  DOING
  REVIEW
  DONE
}

enum MessageStatus {
  OPEN
  IN_PROGRESS
  WAITING_OWNER
  RESOLVED
}

enum OrderStatus {
  NEW
  PENDING_SHIPMENT
  SHIPPED
  IN_TRANSIT
  DELIVERED
  AFTER_SALES
  CANCELLED
  RISK
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ListingStatus {
  IDEA
  PRICING
  CONTENT
  INVENTORY_CHECK
  APPROVAL
  READY_TO_PUBLISH
  PUBLISHED
  ERROR
}

enum PricingStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ApprovalType {
  PRICING
  REFUND
  RESHIPMENT
  LISTING_PUBLISH
  ORDER_RISK
  MESSAGE_ESCALATION
  INVENTORY_PURCHASE
}

enum InventoryStatus {
  NORMAL
  LOW_STOCK
  OUT_OF_STOCK
  RESTOCK_SUGGESTED
  PAUSED_PROMOTION
}

enum DailyBriefingType {
  PLAN
  REVIEW
}

enum ConnectionProvider {
  SHOPEE
  TIKTOK
  MIAOSHOU
  AI
  EXCHANGE_RATE
  PAYMENT
  LOGISTICS
  TAX
}

enum ConnectionStatus {
  NOT_CONNECTED
  RESERVED
  KEY_REQUIRED
  CONNECTED
  ERROR
}

model User {
  id                String            @id @default(cuid())
  email             String            @unique
  passwordHash      String
  name              String
  role              Role
  status            UserStatus        @default(ACTIVE)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  sessions          Session[]
  assignedTasks     Task[]            @relation("AssignedTasks")
  createdTasks      Task[]            @relation("CreatedTasks")
  assignedMessages  CustomerMessage[] @relation("AssignedMessages")
  assignedOrders    Order[]           @relation("AssignedOrders")
  ownedListings     Listing[]         @relation("OwnedListings")
  pricingSubmitted  PricingRule[]     @relation("PricingSubmittedBy")
  pricingApproved   PricingRule[]     @relation("PricingApprovedBy")
  approvalsRequested Approval[]       @relation("ApprovalsRequestedBy")
  approvalsAssigned Approval[]        @relation("ApprovalsAssignedTo")
  activities        Activity[]
  dailyBriefings    DailyBriefing[]
  contentVersions   ContentVersion[]
  auditLogs         AuditLog[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)
  platform    Platform   @default(INTERNAL)
  relatedType String?
  relatedId   String?
  assigneeId  String?
  createdById String?
  dueAt       DateTime?
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  assignee    User?      @relation("AssignedTasks", fields: [assigneeId], references: [id], onDelete: SetNull)
  creator     User?      @relation("CreatedTasks", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([status, platform])
  @@index([assigneeId])
  @@index([relatedType, relatedId])
}

model CustomerMessage {
  id              String        @id @default(cuid())
  platform        Platform      @default(SHOPEE)
  customerName    String
  externalThreadId String?
  subject         String
  message         String
  status          MessageStatus @default(OPEN)
  priority        Priority      @default(MEDIUM)
  assigneeId      String?
  relatedOrderId  String?
  lastReplyAt     DateTime?
  dueAt           DateTime?
  aiDraft         String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  assignee        User?         @relation("AssignedMessages", fields: [assigneeId], references: [id], onDelete: SetNull)
  relatedOrder    Order?        @relation(fields: [relatedOrderId], references: [id], onDelete: SetNull)

  @@index([status, priority])
  @@index([assigneeId])
  @@index([relatedOrderId])
}

model MessageTemplate {
  id        String   @id @default(cuid())
  title     String
  category  String
  contentZh String
  contentEn String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id              String            @id @default(cuid())
  platform        Platform          @default(SHOPEE)
  externalOrderId String
  customerName    String
  status          OrderStatus       @default(PENDING_SHIPMENT)
  skuCount        Int               @default(0)
  totalAmount     Decimal?
  estimatedProfit Decimal?
  riskLevel       RiskLevel         @default(LOW)
  riskFlags       Json              @default("[]")
  assigneeId      String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  assignee        User?             @relation("AssignedOrders", fields: [assigneeId], references: [id], onDelete: SetNull)
  messages        CustomerMessage[]

  @@unique([platform, externalOrderId])
  @@index([status, platform])
  @@index([riskLevel])
  @@index([assigneeId])
}

model Listing {
  id          String        @id @default(cuid())
  title       String
  sku         String
  platform    Platform      @default(SHOPEE)
  status      ListingStatus @default(IDEA)
  ownerId     String?
  cost        Decimal?
  targetPrice Decimal?
  currentStep String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  owner       User?         @relation("OwnedListings", fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([sku])
  @@index([status, platform])
  @@index([ownerId])
}

model PricingRule {
  id                    String        @id @default(cuid())
  sku                   String
  productName           String
  cost                  Decimal
  domesticShipping      Decimal
  internationalShipping Decimal
  packagingCost         Decimal
  platformFeeRate       Decimal
  paymentFeeRate        Decimal
  adCost                Decimal
  returnLossRate        Decimal
  exchangeRate          Decimal
  taxReserveRate        Decimal
  targetMarginRate      Decimal
  minimumPrice          Decimal
  suggestedPrice        Decimal
  campaignFloorPrice    Decimal
  status                PricingStatus @default(DRAFT)
  submittedById         String?
  approvedById          String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  submitter             User?         @relation("PricingSubmittedBy", fields: [submittedById], references: [id], onDelete: SetNull)
  approver              User?         @relation("PricingApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([sku])
  @@index([status])
  @@index([submittedById])
}

model Approval {
  id            String         @id @default(cuid())
  type          ApprovalType
  title         String
  description   String?
  status        ApprovalStatus @default(PENDING)
  requestedById String?
  approverId    String?
  relatedType   String?
  relatedId     String?
  decisionNote  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  requestedBy   User?          @relation("ApprovalsRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)
  approver      User?          @relation("ApprovalsAssignedTo", fields: [approverId], references: [id], onDelete: SetNull)

  @@index([status, type])
  @@index([requestedById])
  @@index([approverId])
  @@index([relatedType, relatedId])
}

model InventoryItem {
  id          String          @id @default(cuid())
  sku         String          @unique
  productName String
  available   Int             @default(0)
  safetyStock Int             @default(0)
  incoming    Int             @default(0)
  status      InventoryStatus @default(NORMAL)
  note        String?
  updatedAt   DateTime        @updatedAt

  @@index([status])
}

model Activity {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  action     String
  content    String
  userId     String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([userId])
}

model DailyBriefing {
  id          String            @id @default(cuid())
  date        DateTime
  type        DailyBriefingType @default(PLAN)
  contentJson Json
  createdById String?
  createdAt   DateTime          @default(now())
  creator     User?             @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([date, type])
  @@index([createdById])
}

model ApiConnection {
  id              String             @id @default(cuid())
  provider        ConnectionProvider
  status          ConnectionStatus   @default(RESERVED)
  displayName     String
  lastCheckedAt   DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([provider])
}

model ContentVersion {
  id          String   @id @default(cuid())
  key         String
  language    String
  contentJson Json
  version     Int
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  creator     User?    @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([key, language, version])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action, entityType])
  @@index([createdAt])
}
